---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title"   : {{ post.title | jsonify }},
    "tags"    : "{{ post.tags | join: ', ' }}",
    "url"     : "{{ post.url | relative_url }}",
    "date"    : "{{ post.date | date: '%d.%m.%Y' }}",
    "content" : {{ post.content | strip_html | truncatewords: 50 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
